# LLM (Planner and Wiki agent)
OPENAI_API_KEY=

# LangSmith (tracing / observability for LangChain and LangGraph)
# Get API key at https://smith.langchain.com
# Use lowercase "true" for LANGCHAIN_TRACING_V2.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=university-chat

# Confluence / Syracuse Answers wiki (anonymous access in phase 1; add token if needed later)
CONFLUENCE_BASE_URL=https://answers.atlassian.syr.edu/wiki/rest/api/content

# Wiki MCP defaults
DEFAULT_SEARCH_LIMIT=5
DEFAULT_TOP_K=5
CHUNK_MAX_WORDS=1200
CHUNK_MIN_WORDS=500

# Optional: MCP server path for stdio (used by LangGraph when spawning wiki MCP)
# WIKI_MCP_COMMAND=python
# WIKI_MCP_ARGS=-m,mcp_servers.wiki.server
